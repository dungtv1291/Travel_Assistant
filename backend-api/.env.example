# -------------------------
# App
# -------------------------
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# -------------------------
# Database (PostgreSQL)
# -------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=travel_assistant
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# -------------------------
# Redis
# -------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# -------------------------
# JWT
# Never commit real secrets. Minimum 32 characters each.
# -------------------------
JWT_ACCESS_SECRET=your_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# -------------------------
# External APIs
# Required in production (NODE_ENV=production), optional in development.
# Never commit real keys — use a secret manager in deployed environments.
# -------------------------
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o

WEATHER_API_KEY=your_weather_api_key
WEATHER_API_BASE_URL=https://api.weatherapi.com/v1

TRAVELPAYOUTS_API_TOKEN=your_travelpayouts_api_token
TRAVELPAYOUTS_MARKER=your_travelpayouts_marker
